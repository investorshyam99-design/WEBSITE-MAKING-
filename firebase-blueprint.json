{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productName": { "type": "string" },
        "size": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "size", "price", "status", "createdAt"]
    }
  },
  "firestore": {
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Orders placed by users"
    }
  }
}
