rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'investorshyam99@gmail.com';
    }

    match /visitors/{visitorId} {
      allow read: if isAdmin();
      allow create, update: if true;
    }

    match /users/{userId} {
      allow read: if isAdmin();
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow list: if request.auth != null;
      allow create: if true;
      allow update: if request.auth != null; 
      allow delete: if request.auth != null;
    }

    match /draft_orders/{draftId} {
      allow read, create, update: if true;
    }

    match /manual_profits_daily/{docId} {
      allow read, write: if isAdmin();
    }

    match /login_sessions/{sessionId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
    }

    match /abandoned_carts/{cartId} {
      allow read: if isAdmin();
      allow create, update, delete: if request.auth != null && request.auth.uid == cartId;
    }
  }
}
